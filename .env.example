# EmailJS credentials used by the contact form (src/components/sections/ContactCTA.tsx)
# Create a free account at https://www.emailjs.com, connect a Gmail service,
# and create a template with the fields: from_name, from_email, phone, message, to_email.

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
